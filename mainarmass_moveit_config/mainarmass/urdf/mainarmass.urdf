<?xml version="1.0"?>
<robot name="mainarmass">
    <material name="gray"><color rgba="0.647 0.647 0.647 1"/></material>
    <material name="black"><color rgba="0.529 0.568 0.6 1"/></material>
    <material name="red"><color rgba="0.301 0.290 0.262 1"/></material>
    <material name="dark_gray"><color rgba="0.4 0.4 0.4 1"/></material>
    <material name="white"><color rgba="0.901 0.901 0.901 1"/></material>
    <material name="light_blue"><color rgba="0.811 0.858 0.898 1"/></material>

    <link name="root" />

    <link name="Base">
        <inertial>
            <mass value="0.217226" />
            <origin xyz="0 0 0.005" rpy="0 0 0" />
            <inertia ixx="0.000948" ixy="0" ixz="0" iyy="0.000948" iyz="0" izz="0.001894" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry><mesh filename="package://mainarmass/meshes/67.stl" scale="1 1 1" /></geometry>
            <material name="gray"/>
        </visual>
    </link>

    <link name="Shoulder">
        <inertial>
            <mass value="59.0911" />
            <origin xyz="0.0015 0.0238 0.0500" rpy="0 0 0" />
            <inertia ixx="0.3261" ixy="0.0555" ixz="-0.0050" iyy="0.4205" iyz="-0.0286" izz="0.6275" />
        </inertial>
        <visual>
            <origin xyz="0.0637 0.1917 0.0902" rpy="0 0 0" />
            <geometry><mesh filename="package://mainarmass/meshes/63.stl" scale="1 1 1" /></geometry>
            <material name="dark_gray"/>
        </visual>
    </link>

    <link name="UpperArm">
        <inertial>
            <mass value="40.1813" />
            <origin xyz="0.0016 0.0003 0.0734" rpy="0 0 0" />
            <inertia ixx="0.8193" ixy="-0.0077" ixz="0.0436" iyy="0.8412" iyz="0.1480" izz="0.1764" />
        </inertial>
        <visual>
            <origin xyz="-0.0453 0.1279 0.0401" rpy="0 0 0" />
            <geometry><mesh filename="package://mainarmass/meshes/75.stl" scale="1 1 1" /></geometry>
            <material name="white"/>
        </visual>
    </link>

    <link name="Forearm">
        <inertial>
            <mass value="29.5338" />
            <origin xyz="-0.0255 -0.0694 -0.1516" rpy="0 0 0" />
            <inertia ixx="1.1872" ixy="-0.0724" ixz="-0.1595" iyy="1.0148" iyz="-0.4378" izz="0.2615" />
        </inertial>
        <visual>
            <origin xyz="0.0640 0.2460 -0.3971" rpy="0 0 0" />
            <geometry><mesh filename="package://mainarmass/meshes/79.stl" scale="1 1 1" /></geometry>
            <material name="black"/>
        </visual>
    </link>

    <link name="Wrist">
        <inertial>
            <mass value="0.81762" />
            <origin xyz="-0.0285 0.0006 0.0133" rpy="0 0 0" />
            <inertia ixx="0.000344" ixy="-0.000069" ixz="0.000106" iyy="0.000371" iyz="0.000039" izz="0.000269" />
        </inertial>
        <visual>
            <origin xyz="0.1232 0.3795 0.0397" rpy="0 0 0" />
            <geometry><mesh filename="package://mainarmass/meshes/59.stl" scale="1 1 1" /></geometry>
            <material name="light_blue"/>
        </visual>
    </link>

    <link name="Paddle">
        <inertial>
            <mass value="9.05818" />
            <origin xyz="-0.0346 -0.0910 0.1368" rpy="0 0 0" />
            <inertia ixx="0.0518" ixy="-0.0068" ixz="0.0057" iyy="0.0352" iyz="0.0143" izz="0.0220" />
