            <geometry><mesh filename="package://mainarmass/meshes/71.stl" scale="1 1 1" /></geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="root_to_base" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="root" />
        <child link="Base" />
    </joint>

    <joint name="BaseRotate_0" type="continuous">
        <origin xyz="0 0 0" rpy="0.01712 0.04808 -0.38348" />
        <axis xyz="0.04806 -0.01710 -0.99869" />
        <parent link="Base" />
        <child link="Shoulder" />
    </joint>

    <joint name="UpperArmRotate_0" type="continuous">
        <origin xyz="-0.01750 -0.03317 0.10511" rpy="-0.08249 -0.02327 0.02051" />
        <axis xyz="0.93476 -0.35525 0" />
        <parent link="Shoulder" />
        <child link="UpperArm" />
    </joint>

    <joint name="ForeArmRotate_0" type="continuous">
        <origin xyz="-0.03355 -0.08830 0.45530" rpy="-0.06873 0.02609 -0.00089" />
        <axis xyz="0.93476 -0.35525 0" />
        <parent link="UpperArm" />
        <child link="Forearm" />
    </joint>

    <joint name="WristRotate_0" type="continuous">
        <origin xyz="-0.10957 -0.19888 -0.43388" rpy="-0.84990 0.27810 3.0151" />
        <axis xyz="0.93476 -0.35525 0" />
        <parent link="Forearm" />
        <child link="Wrist" />
    </joint>

    <joint name="PaddleRotate_0" type="continuous">
        <origin xyz="-0.04174 -0.00429 0.02647" rpy="0 0 0" />
        <axis xyz="0.20602 0.54209 -0.81467" />
        <parent link="Wrist" />
