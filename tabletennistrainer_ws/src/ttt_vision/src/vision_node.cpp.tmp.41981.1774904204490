#include <rclcpp/rclcpp.hpp>
#include <sensor_msgs/msg/image.hpp>
#include <ttt_msgs/msg/ball_detection.hpp>
#include <cv_bridge/cv_bridge.h>
#include <opencv2/opencv.hpp>
#include <opencv2/cudafilters.hpp>
#include <opencv2/cudaarithm.hpp>
#include <algorithm>
#include <deque>

class VisionNode : public rclcpp::Node {
public:
    VisionNode() : Node("vision_node") {
        this->declare_parameter("camera_id",       "left");
        this->declare_parameter("min_area",          8);    // minimum blob area (px²)
        this->declare_parameter("max_area",       2000);   // maximum blob area (px²)
        this->declare_parameter("edge_margin",      10);
        this->declare_parameter("motion_threshold", 15);  // pixel diff to flag as motion
        this->declare_parameter("min_contrast",     30);  // blob interior vs annulus in orig frame
        this->declare_parameter("dilate_iters",      3);  // fill ball blob after diff
        this->declare_parameter("consistency_min",   2);  // hits required in 3-frame window
        this->declare_parameter("kf_gate_px",       50.0);
        this->declare_parameter("kf_reset_misses",  10);
        this->declare_parameter("table_roi", std::vector<int64_t>{});

        camera_id_        = this->get_parameter("camera_id").as_string();
        min_radius_       = this->get_parameter("min_radius").as_int();
        max_radius_       = this->get_parameter("max_radius").as_int();
        edge_margin_      = this->get_parameter("edge_margin").as_int();
        motion_threshold_ = this->get_parameter("motion_threshold").as_int();
        min_contrast_     = this->get_parameter("min_contrast").as_int();
        dilate_iters_     = this->get_parameter("dilate_iters").as_int();
        consistency_min_  = this->get_parameter("consistency_min").as_int();
        kf_gate_px_sq_    = std::pow(this->get_parameter("kf_gate_px").as_double(), 2.0);
        kf_reset_misses_  = this->get_parameter("kf_reset_misses").as_int();

        auto roi_vec = this->get_parameter("table_roi").as_integer_array();
        if (roi_vec.size() == 8) {
            for (int i = 0; i < 4; i++)
                table_roi_.emplace_back((int)roi_vec[i*2], (int)roi_vec[i*2+1]);
            auto_detect_ = false;
            RCLCPP_INFO(this->get_logger(),
                "[%s] Manual table ROI: (%ld,%ld) (%ld,%ld) (%ld,%ld) (%ld,%ld)",
                camera_id_.c_str(),
                roi_vec[0],roi_vec[1], roi_vec[2],roi_vec[3],
                roi_vec[4],roi_vec[5], roi_vec[6],roi_vec[7]);
        } else {
            auto_detect_ = true;
            RCLCPP_INFO(this->get_logger(),
                "[%s] Auto table-detect ON", camera_id_.c_str());
        }

        gaussian_filter_ = cv::cuda::createGaussianFilter(CV_8UC1, CV_8UC1, cv::Size(5, 5), 0);
        dilate_kernel_   = cv::getStructuringElement(cv::MORPH_ELLIPSE, cv::Size(7, 7));
        open_kernel_     = cv::getStructuringElement(cv::MORPH_ELLIPSE, cv::Size(3, 3));
        detect_kernel_   = cv::getStructuringElement(cv::MORPH_ELLIPSE, cv::Size(9, 9));

        // Kalman filter — state [x, y, vx, vy], measurement [x, y]
        kf_ = cv::KalmanFilter(4, 2, 0, CV_32F);
        kf_.measurementMatrix = (cv::Mat_<float>(2, 4) <<
            1, 0, 0, 0,
            0, 1, 0, 0);
        cv::setIdentity(kf_.processNoiseCov,     cv::Scalar::all(1e-4f));
        cv::setIdentity(kf_.measurementNoiseCov, cv::Scalar::all(0.1f));
        cv::setIdentity(kf_.errorCovPost,        cv::Scalar::all(1.0f));

        // Live parameter callback — lets the GUI push a new table_roi without restarting
        param_cb_ = this->add_on_set_parameters_callback(
            [this](const std::vector<rclcpp::Parameter>& params) {
                rcl_interfaces::msg::SetParametersResult res;
                res.successful = true;
                for (const auto& p : params) {
                    if (p.get_name() != "table_roi") continue;
                    auto vals = p.as_integer_array();
                    if (vals.empty()) {
                        table_roi_.clear();
                        roi_mask_ = cv::Mat();
                        auto_detect_ = true;
                        detect_attempt_ = 0;
                        RCLCPP_INFO(this->get_logger(),
                            "[%s] ROI cleared — auto-detect resumed", camera_id_.c_str());
                    } else if (vals.size() >= 8 && vals.size() % 2 == 0) {
                        table_roi_.clear();
                        for (size_t i = 0; i < vals.size(); i += 2)
                            table_roi_.emplace_back((int)vals[i], (int)vals[i+1]);
                        roi_mask_ = cv::Mat(); // rebuilt on next frame
                        auto_detect_ = false;
                        RCLCPP_INFO(this->get_logger(),
                            "[%s] ROI updated live: %zu corners", camera_id_.c_str(), table_roi_.size());
                    } else {
                        res.successful = false;
                        res.reason = "table_roi needs 8+ integers (4 x,y pairs)";
                    }
                }
                return res;
            });

        image_sub_ = this->create_subscription<sensor_msgs::msg::Image>(
            "/camera/" + camera_id_ + "/image_raw", 10,
            std::bind(&VisionNode::imageCallback, this, std::placeholders::_1));

        detection_pub_ = this->create_publisher<ttt_msgs::msg::BallDetection>(
            "/ball_detection/" + camera_id_, 10);

        RCLCPP_INFO(this->get_logger(),
            "[%s] Vision node online | motion>%d contrast>%d r=[%d-%d]",
            camera_id_.c_str(), motion_threshold_, min_contrast_, min_radius_, max_radius_);
    }

private:
    // ── Auto-detect table from dark surface ──────────────────────────────────
    void autoDetectTable(const cv::Mat& gray) {
        // The table surface is near-black (~5-30 DN at 240fps exposure).
        // Background, even when dark-looking, is typically 40+ DN.
        // Use a low fixed threshold to isolate only the truly black table.
        cv::Mat dark;
        cv::threshold(gray, dark, 35, 255, cv::THRESH_BINARY_INV);

        // Erode first to break thin connections between dark table and dark
        // background areas before close/open, so they don't merge into one blob.
        cv::erode(dark, dark, detect_kernel_);
        cv::morphologyEx(dark, dark, cv::MORPH_CLOSE, detect_kernel_);
        cv::morphologyEx(dark, dark, cv::MORPH_OPEN,  detect_kernel_);

        std::vector<std::vector<cv::Point>> contours;
        cv::findContours(dark, contours, cv::RETR_EXTERNAL, cv::CHAIN_APPROX_SIMPLE);
        if (contours.empty()) return;

        std::sort(contours.begin(), contours.end(),
            [](const auto& a, const auto& b){ return cv::contourArea(a) > cv::contourArea(b); });

        double frame_area  = gray.cols * gray.rows;
        double min_area    = frame_area * 0.10; // table must be ≥10% of frame
        double max_area    = frame_area * 0.92; // reject if it swallows whole frame

        for (const auto& c : contours) {
            double ca = cv::contourArea(c);
            if (ca < min_area) break;
            if (ca > max_area) continue; // whole-frame detection — skip

            std::vector<cv::Point> approx;
            cv::approxPolyDP(c, approx, 0.03 * cv::arcLength(c, true), true);
            std::vector<cv::Point> hull;
            cv::convexHull(approx, hull);
            if (hull.size() < 4 || hull.size() > 6) continue;

            table_roi_ = hull;

            // Write back to ROS parameter so the GUI ROI poller can read it
            std::vector<int64_t> roi_param;
            for (const auto& pt : hull) {
                roi_param.push_back(pt.x);
                roi_param.push_back(pt.y);
            }
            this->set_parameter(rclcpp::Parameter("table_roi", roi_param));

            RCLCPP_INFO(this->get_logger(),
                "[%s] Table auto-detected: %zu corners, %.0f%% of frame — ROI locked",
                camera_id_.c_str(), hull.size(), 100.0 * ca / frame_area);
            return;
        }
        RCLCPP_WARN_THROTTLE(this->get_logger(), *this->get_clock(), 2000,
            "[%s] Auto-detect: no table yet (attempt %d)", camera_id_.c_str(), detect_attempt_);
    }

    // ── Contrast check: mean brightness inside blob vs surrounding annulus ───
    // Returns (interior_mean - annulus_mean). High = bright object on dark bg.
    double localContrast(const cv::Mat& gray, cv::Point2f center, float radius) {
        int cx = std::clamp((int)center.x, 0, gray.cols - 1);
        int cy = std::clamp((int)center.y, 0, gray.rows - 1);
        int inner_r = std::max(1, (int)radius);
        int outer_r = std::max(inner_r + 2, (int)(radius * 2.5f));

        cv::Mat inner_mask = cv::Mat::zeros(gray.size(), CV_8UC1);
        cv::Mat outer_mask = cv::Mat::zeros(gray.size(), CV_8UC1);
        cv::circle(inner_mask, cv::Point(cx, cy), inner_r, 255, -1);
        cv::circle(outer_mask, cv::Point(cx, cy), outer_r, 255, -1);
        cv::subtract(outer_mask, inner_mask, outer_mask); // annulus only

        double mean_in  = cv::mean(gray, inner_mask)[0];
        double mean_out = cv::mean(gray, outer_mask)[0];
        return mean_in - mean_out;
    }

    // ── Main callback ─────────────────────────────────────────────────────────
    void imageCallback(const sensor_msgs::msg::Image::SharedPtr msg) {
        cv::Mat img;
        try {
            img = cv_bridge::toCvShare(msg, "mono8")->image;
        } catch (const cv_bridge::Exception& e) {
            RCLCPP_ERROR(this->get_logger(), "cv_bridge: %s", e.what());
            return;
        }
        if (img.empty()) return;

        // Auto-detect table ROI every 10 frames until locked
        if (auto_detect_ && table_roi_.empty()) {
            if (++detect_attempt_ % 10 == 1)
                autoDetectTable(img);
        }

        // Build ROI mask once (or when frame size changes)
        if (!table_roi_.empty() &&
            (roi_mask_.empty() || roi_mask_.size() != img.size())) {
            roi_mask_ = cv::Mat::zeros(img.size(), CV_8UC1);
            cv::fillPoly(roi_mask_,
                std::vector<std::vector<cv::Point>>{table_roi_}, 255);
        }

        // ── GPU: blur → 3-frame diff → motion mask ───────────────────────────
        gpu_frame_.upload(img);
        gaussian_filter_->apply(gpu_frame_, gpu_blurred_);

        if (gpu_prev_blurred_.empty()) {
            gpu_blurred_.copyTo(gpu_prev_blurred_);
            return;
        }
        if (gpu_prev2_blurred_.empty()) {
            gpu_prev_blurred_.copyTo(gpu_prev2_blurred_);
            gpu_blurred_.copyTo(gpu_prev_blurred_);
            return;
        }

        // Diff against t-2 for a stronger motion signal
        cv::cuda::absdiff(gpu_blurred_, gpu_prev2_blurred_, gpu_diff_);
        cv::cuda::threshold(gpu_diff_, gpu_motion_, motion_threshold_, 255, cv::THRESH_BINARY);

        gpu_prev_blurred_.copyTo(gpu_prev2_blurred_);
        gpu_blurred_.copyTo(gpu_prev_blurred_);

        cv::Mat motion_mask;
        gpu_motion_.download(motion_mask);

        // ── CPU: morphology → apply ROI ───────────────────────────────────────
        for (int i = 0; i < dilate_iters_; i++)
            cv::dilate(motion_mask, motion_mask, dilate_kernel_);
        cv::morphologyEx(motion_mask, motion_mask, cv::MORPH_OPEN, open_kernel_);

        if (!roi_mask_.empty())
            cv::bitwise_and(motion_mask, roi_mask_, motion_mask);

        // ── Find candidate blobs ──────────────────────────────────────────────
        std::vector<std::vector<cv::Point>> contours;
        cv::findContours(motion_mask, contours, cv::RETR_EXTERNAL, cv::CHAIN_APPROX_SIMPLE);

        float best_x = -1.0f, best_y = -1.0f, best_r = 0.0f, best_contrast = 0.0f;
        bool found = false;

        for (const auto& contour : contours) {
            if (cv::contourArea(contour) < 4) continue;

            cv::Point2f center;
            float radius;
            cv::minEnclosingCircle(contour, center, radius);

            // Size gate
            if (radius < min_radius_ || radius > max_radius_) continue;

            // Edge margin gate
            if (center.x < edge_margin_ || center.x > img.cols - edge_margin_) continue;
            if (center.y < edge_margin_ || center.y > img.rows - edge_margin_) continue;

            // Contrast gate: bright blob on dark table → high positive contrast.
            // Eliminates camera noise (flat surroundings) and shadow blobs (dark center).
            double contrast = localContrast(img, center, radius);
            if (contrast < min_contrast_) continue;

            if (contrast > best_contrast) {
                best_contrast = static_cast<float>(contrast);
                best_x = center.x;
                best_y = center.y;
                best_r = radius;
                found = true;
            }
        }

        // ── Temporal consistency ──────────────────────────────────────────────
        consistency_buf_.push_back(found);
        if ((int)consistency_buf_.size() > 3) consistency_buf_.pop_front();
        int hit_count = std::count(consistency_buf_.begin(), consistency_buf_.end(), true);
        bool consistent = (hit_count >= consistency_min_);

        // ── Kalman filter predict / update ────────────────────────────────────
        double t_now = rclcpp::Time(msg->header.stamp).seconds();

        if (kf_initialized_) {
            float dt = std::clamp((float)(t_now - last_stamp_), 0.001f, 0.1f);
            last_stamp_ = t_now;

            kf_.transitionMatrix = (cv::Mat_<float>(4, 4) <<
                1, 0, dt,  0,
                0, 1,  0, dt,
                0, 0,  1,  0,
                0, 0,  0,  1);
            kf_.predict();

            if (found) {
                float dx = best_x - kf_.statePre.at<float>(0);
                float dy = best_y - kf_.statePre.at<float>(1);
                if (dx*dx + dy*dy <= kf_gate_px_sq_) {
                    cv::Mat meas = (cv::Mat_<float>(2, 1) << best_x, best_y);
                    kf_.correct(meas);
                    miss_count_ = 0;
                } else {
                    kf_.statePre.copyTo(kf_.statePost);
                    miss_count_++;
                }
            } else {
                kf_.statePre.copyTo(kf_.statePost);
                miss_count_++;
            }

            if (miss_count_ >= kf_reset_misses_) {
                kf_initialized_ = false;
                miss_count_ = 0;
                consistency_buf_.clear();
            }
        } else if (consistent && found) {
            kf_.statePost = (cv::Mat_<float>(4, 1) << best_x, best_y, 0.0f, 0.0f);
            cv::setIdentity(kf_.errorCovPost, cv::Scalar::all(100.0f));
            kf_initialized_ = true;
            last_stamp_ = t_now;
            miss_count_ = 0;
        }

        // ── Publish ───────────────────────────────────────────────────────────
        auto det_msg = ttt_msgs::msg::BallDetection();
        det_msg.header = msg->header;
        det_msg.x = -1.0f; det_msg.y = -1.0f;

        if (kf_initialized_) {
            det_msg.x          = kf_.statePost.at<float>(0);
            det_msg.y          = kf_.statePost.at<float>(1);
            det_msg.radius     = found ? best_r        : 0.0f;
            det_msg.confidence = found ? best_contrast : 0.0f;
        }
        detection_pub_->publish(det_msg);
    }

    // ── Members ───────────────────────────────────────────────────────────────
    std::string camera_id_;
    int min_radius_, max_radius_, edge_margin_, motion_threshold_, min_contrast_, dilate_iters_;
    bool auto_detect_ = false;
    int detect_attempt_ = 0;
    std::vector<cv::Point> table_roi_;
    cv::Mat roi_mask_, dilate_kernel_, open_kernel_, detect_kernel_;

    cv::cuda::GpuMat gpu_frame_, gpu_blurred_, gpu_prev_blurred_, gpu_prev2_blurred_;
    cv::cuda::GpuMat gpu_diff_, gpu_motion_;
    cv::Ptr<cv::cuda::Filter> gaussian_filter_;

    int consistency_min_;
    std::deque<bool> consistency_buf_;

    cv::KalmanFilter kf_;
    bool kf_initialized_ = false;
    int miss_count_ = 0;
    double last_stamp_ = 0.0;
    float kf_gate_px_sq_;
    int kf_reset_misses_;

    rclcpp::node_interfaces::OnSetParametersCallbackHandle::SharedPtr param_cb_;
    rclcpp::Subscription<sensor_msgs::msg::Image>::SharedPtr image_sub_;
    rclcpp::Publisher<ttt_msgs::msg::BallDetection>::SharedPtr detection_pub_;
};

int main(int argc, char** argv) {
    rclcpp::init(argc, argv);
    rclcpp::spin(std::make_shared<VisionNode>());
    rclcpp::shutdown();
    return 0;
}
