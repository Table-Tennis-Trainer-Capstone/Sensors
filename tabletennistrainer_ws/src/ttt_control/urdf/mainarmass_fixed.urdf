<robot name="mainarmass">
    <material name="black"><color rgba="0.529 0.568 0.6 1" /></material>
    <material name="orange"><color rgba="1.0 0.5 0.0 1.0" /></material>
    <material name="table_color"><color rgba="0.1 0.2 0.3 0.8" /></material>

    <link name="table_center">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry><sphere radius="0.05"/></geometry>
            <material name="orange" />
        </visual>
    </link>

    <link name="table_surface">
        <visual>
            <origin xyz="-1.37 0.0 -0.01" rpy="0.0 0.0 0.0" />
            <geometry><box size="2.74 1.52 0.02" /></geometry>
            <material name="table_color" />
        </visual>
        <collision>
            <origin xyz="-1.37 0.0 0.05" rpy="0 0 0" />
            <geometry><box size="2.74 1.52 0.02" /></geometry>
        </collision>
    </link>

    <joint name="center_to_table" type="fixed">
        <parent link="table_center" />
        <child link="table_surface" />
        <origin xyz="0 0 0" rpy="0 0 0" /> 
    </joint>

    <link name="root">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry><sphere radius="0.001"/></geometry>
            <material name="black" />
        </visual>
    </link>

    <joint name="center_to_robot" type="fixed">
        <parent link="table_center" />
        <child link="root" />
        <origin xyz="-1.37 0 0" rpy="0 0 0" /> 
    </joint>

    <joint name="root_to_base" type="fixed">
        <!-- Added 45 deg (0.7854 rad) to yaw to match physical diagonal desk mount -->
        <origin xyz="0 0 0" rpy="0 0 2.3736" />
        <parent link="root" />
        <child link="Base" />
    </joint>


    <link name="Base">
        <inertial>
            <mass value="0.219" />
            <origin xyz="0 0 0.005" rpy="0 0 0" />
            <inertia ixx="0.0009559" ixy="0" ixz="0" iyy="0.0009559" iyz="0" izz="0.00190814" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/67.stl" scale="1 1 1" /></geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/67.stl" scale="1 1 1" /></geometry>
        </collision>
    </link>

    <link name="Shoulder">
        <inertial>
            <mass value="3.232" />
            <origin xyz="0.0015 0.0238 0.0500" rpy="0 0 0" />
            <inertia ixx="0.01827653" ixy="0.00349413" ixz="-0.00033063" iyy="0.01968154" iyz="-0.00175414" izz="0.03042546" />
        </inertial>
        <visual>
            <origin xyz="0.0637 0.1917 0.0902" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/63.stl" scale="1 1 1" /></geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0.0637 0.1917 0.0902" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/63.stl" scale="1 1 1" /></geometry>
        </collision>
    </link>

    <link name="UpperArm">
        <inertial>
            <mass value="1.456" />
            <origin xyz="0.0016 0.0003 0.0734" rpy="0 0 0" />
            <inertia ixx="0.02606584" ixy="-0.00147774" ixz="0.00295468" iyy="0.02661382" iyz="0.00583087" izz="0.00673394" />
        </inertial>
        <visual>
            <origin xyz="-0.0453 0.1279 0.0401" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/75.stl" scale="1 1 1" /></geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="-0.0453 0.1279 0.0401" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/75.stl" scale="1 1 1" /></geometry>
        </collision>
    </link>

    <link name="Forearm">
        <inertial>
            <mass value="0.757" />
            <origin xyz="-0.0255 -0.0694 -0.1516" rpy="0 0 0" />
            <inertia ixx="0.02490527" ixy="-0.00176138" ixz="-0.00375067" iyy="0.02114019" iyz="-0.00953407" izz="0.00606278" />
        </inertial>
        <visual>
            <origin xyz="0.0640 0.2460 -0.3971" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/79.stl" scale="1 1 1" /></geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0.0640 0.2460 -0.3971" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/79.stl" scale="1 1 1" /></geometry>
        </collision>
    </link>

    <link name="Wrist">
        <inertial>
            <mass value="0.086" />
            <origin xyz="-0.0285 0.0006 0.0133" rpy="0 0 0" />
            <inertia ixx="0.00004728" ixy="-0.00001086" ixz="0.00002008" iyy="0.00005686" iyz="0.00000813" izz="0.00003823" />
        </inertial>
        <visual>
            <origin xyz="0.1232 0.3795 0.0397" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/59.stl" scale="1 1 1" /></geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0.1232 0.3795 0.0397" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/59.stl" scale="1 1 1" /></geometry>
        </collision>
    </link>

    <link name="Paddle">
        <inertial>
            <mass value="0.355" />
            <origin xyz="-0.0346 -0.0910 0.1368" rpy="0 0 0" />
            <inertia ixx="0.00254292" ixy="-0.0003235" ixz="0.00032513" iyy="0.00177002" iyz="0.00082579" izz="0.00103777" />
        </inertial>
        <visual>
            <origin xyz="0.1494 0.3836 -0.0516" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/71.stl" scale="1 1 1" /></geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0.1494 0.3836 -0.0516" rpy="0 0 0" />
            <geometry><mesh filename="package://ttt_control/meshes/71.stl" scale="1 1 1" /></geometry>
        </collision>
    </link>

    <link name="paddle_tcp">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
            <geometry><sphere radius="0.01"/></geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
            <geometry><sphere radius="0.01"/></geometry>
        </collision>
    </link>

    <joint name="BaseRotate_0" type="revolute">
        <origin xyz="0 0 0" rpy="0.01712 0.04808 -0.38348" />
        <axis xyz="0.04806 -0.01710 0.99869" /> 
        <parent link="Base" />
        <child link="Shoulder" />
        <limit lower="-2.0944" upper="2.0944" effort="35.0" velocity="5" />
    </joint>

    <joint name="UpperArmRotate_0" type="revolute">
        <origin xyz="-0.01750 -0.03317 0.10511" rpy="-0.08249 -0.02327 0.02051" />
        <axis xyz="0.93476 -0.35525 0" />
        <parent link="Shoulder" />
        <child link="UpperArm" />
        <limit lower="-0.261799" upper="0.5236" effort="30.0" velocity="5" />
    </joint>

    <joint name="ForeArmRotate_0" type="revolute">
        <origin xyz="-0.03355 -0.08830 0.45530" rpy="-0.06873 0.02609 -0.00089" />
        <axis xyz="-0.93476 0.35525 0" /> 
        <parent link="UpperArm" />
        <child link="Forearm" />
        <limit lower="-0.436332" upper="1.0472" effort="12.0" velocity="5" />
    </joint>

    <joint name="WristRotate_0" type="revolute">
        <origin xyz="-0.10957 -0.19888 -0.43388" rpy="-2.48921 0.22754 2.49360" />
        <axis xyz="0.93476 -0.35525 0" />
        <parent link="Forearm" />
        <child link="Wrist" />
        <limit lower="-3.14159" upper="0" effort="0.75" velocity="5" />
    </joint>

    <joint name="PaddleRotate_0" type="revolute">
        <origin xyz="-0.04174 -0.00429 0.02647" rpy="0 0 0" />
        <axis xyz="0.20602 0.54209 -0.81467" />
        <parent link="Wrist" />
        <child link="Paddle" />
        <limit lower="-1.5708" upper="1.5708" effort="0.75" velocity="5" />
    </joint>
    
    <joint name="paddle_to_tcp" type="fixed">
        <parent link="Paddle" />
        <child link="paddle_tcp" />
        <origin xyz="-0.033 -0.105 0.149" rpy="-0.587 0.245 -1.933" />
    </joint>
</robot>
